# ─── Supabase ───────────────────────────────────────────────
# Project URL — Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public key — Supabase Dashboard → Project Settings → API → anon public
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Google Books API ────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Books API → Credentials
VITE_GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# ─── Google Gemini AI ────────────────────────────────────────
# https://aistudio.google.com → Get API Key
VITE_GEMINI_API_KEY=your-gemini-api-key
